<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <!-- Top App Bar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/emerald_primary"
            android:elevation="4dp"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@android:color/white"
            app:title="Настройки"
            app:titleTextColor="@android:color/white"
            app:titleCentered="true" />

        <!-- Header (removed, now using toolbar) -->

        <!-- Server Configuration Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🌐 Сервер"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"
                    android:textColor="?attr/colorOnSurface"
                    android:gravity="center" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="URL сервера"
                    android:textSize="13sp"
                    android:layout_marginBottom="6dp"
                    android:textColor="?android:attr/textColorSecondary" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:boxBackgroundMode="outline">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/serverUrlInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:hint="https://childwatch-production.up.railway.app" />

                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/useVpsBtn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="VPS"
                        android:textSize="14sp"
                        android:textAllCaps="false"
                        style="@style/Widget.Material3.Button" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/useLocalhostBtn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Local"
                        style="@style/Widget.ParentWatch.Button.Outlined" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Device Configuration Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📱 Устройство"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"
                    android:textColor="?attr/colorOnSurface"
                    android:gravity="center" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ID устройства"
                    android:textSize="13sp"
                    android:layout_marginBottom="6dp"
                    android:textColor="?android:attr/textColorSecondary" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:boxBackgroundMode="outline">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/deviceIdText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Не настроен"
                        android:textSize="14sp"
                        android:fontFamily="monospace"
                        android:inputType="none"
                        android:focusable="false"
                        android:clickable="true" />

                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/copyIdButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="📋 Копировать"
                        style="@style/Widget.ParentWatch.Button.Outlined" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/showQrButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📱 QR-код"
                        style="@style/Widget.ParentWatch.Button.Outlined" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Parent Device Connection Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="👨‍👩‍👧 Связь с родителем"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"
                    android:textColor="?attr/colorOnSurface"
                    android:gravity="center" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Для работы функции &quot;Где родители?&quot; отсканируйте QR-код с родительского устройства"
                    android:textSize="13sp"
                    android:layout_marginBottom="12dp"
                    android:textColor="?android:attr/textColorSecondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/scanParentQrButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📷 Сканировать QR родителя"
                    android:textSize="14sp"
                    android:textAllCaps="false"
                    style="@style/Widget.Material3.Button" />

                <TextView
                    android:id="@+id/parentIdStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="❌ Не подключено"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:gravity="center" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- App Tracking Permissions Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📊 Отслеживание приложений"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"
                    android:textColor="?attr/colorOnSurface"
                    android:gravity="center" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Для отображения текущих запущенных приложений на устройстве ребенка необходимо разрешение 'Использование приложений'."
                    android:textSize="13sp"
                    android:layout_marginBottom="12dp"
                    android:textColor="?android:attr/textColorSecondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/requestUsagePermissionButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔓 Предоставить разрешение"
                    style="@style/Widget.ParentWatch.Button.Outlined" />

                <TextView
                    android:id="@+id/usagePermissionStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="✅ Разрешение предоставлено"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:visibility="gone"
                    android:textColor="?attr/colorPrimary" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Notification Settings Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔔 Уведомления"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"
                    android:textColor="?attr/colorOnSurface"
                    android:gravity="center" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Длительность отображения"
                    android:textSize="13sp"
                    android:layout_marginBottom="6dp"
                    android:textColor="?android:attr/textColorSecondary" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/notificationDurationSlider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="5"
                    android:valueTo="30"
                    android:stepSize="5"
                    android:value="10"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/durationValueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10 секунд"
                    android:textSize="14sp"
                    android:layout_gravity="center"
                    android:layout_marginBottom="16dp"
                    android:textColor="?attr/colorPrimary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ℹ️ Уведомления о новых сообщениях будут автоматически скрываться через указанное время."
                    android:textSize="11sp"
                    android:layout_marginBottom="16dp"
                    android:textColor="?android:attr/textColorSecondary" />

                <!-- Sound Switch -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🔊 Звук уведомлений"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/notificationSoundSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />

                </LinearLayout>

                <!-- Vibration Switch -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📳 Вибрация"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/notificationVibrationSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Service Controls Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🛰️ Сервис мониторинга"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"
                    android:textColor="?attr/colorOnSurface"
                    android:gravity="center" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/startStopServiceButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Запустить мониторинг"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    style="@style/Widget.Material3.Button"
                    app:cornerRadius="12dp"
                    app:icon="@android:drawable/ic_media_play" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/emergencyStopButtonSettings"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:text="🚨 Экстренная остановка"
                    style="@style/Widget.ParentWatch.Button.Outlined"
                    app:cornerRadius="10dp"
                    app:icon="@android:drawable/ic_delete" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- About and Diagnostics Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ℹ️ О приложении и диагностика"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"
                    android:textColor="?attr/colorOnSurface"
                    android:gravity="center" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:weightSum="2">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/openAboutButton"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="ℹ️\nО приложении"
                        android:gravity="center"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        style="@style/Widget.ParentWatch.Button.Outlined" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/openStatsButton"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="📊\nСтатистика"
                        android:gravity="center"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        style="@style/Widget.ParentWatch.Button.Outlined" />
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Action Buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            style="@style/Widget.Material3.Button"
            android:text="💾 Сохранить настройки"
            android:textSize="16sp"
            app:icon="@android:drawable/ic_menu_save"
            app:cornerRadius="12dp" />

        <!-- Info Footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="ℹ️ Изменения вступят в силу после перезапуска мониторинга."
            android:textSize="11sp"
            android:gravity="center"
            android:textColor="?android:attr/textColorSecondary" />

    </LinearLayout>

</ScrollView>
