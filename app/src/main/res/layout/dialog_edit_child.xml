<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Avatar Section -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/avatarCard"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center_horizontal"
            app:cardCornerRadius="60dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="8dp">

            <ImageView
                android:id="@+id/childAvatarImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_myplaces"
                android:contentDescription="Фото ребенка" />

        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/changeAvatarButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Выбрать фото"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/selectContactButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Из контактов"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:icon="@android:drawable/ic_menu_search"
                app:iconGravity="start" />

        </LinearLayout>

        <!-- Device ID with paste button -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/deviceIdInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Device ID *"
            app:helperText="Отсканируйте QR-код или вставьте из буфера"
            app:helperTextEnabled="true"
            app:endIconMode="custom"
            app:endIconDrawable="@android:drawable/ic_menu_upload"
            app:endIconContentDescription="Вставить из буфера"
            android:layout_marginBottom="8dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/deviceIdInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text|textNoSuggestions"
                android:importantForAutofill="no"
                android:maxLines="1"
                android:fontFamily="monospace"
                android:textSize="14sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- QR Code Scan Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/scanQrButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📷 Сканировать QR-код"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp" />

        <!-- Child Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/childNameInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Имя ребенка *"
            app:helperText="Или выберите из контактов выше"
            app:helperTextEnabled="true"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/childNameInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName|textCapWords"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Age -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/childAgeInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Возраст"
            app:helperText="Опционально"
            app:helperTextEnabled="true"
            app:suffixText="лет"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/childAgeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Role -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/roleInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Роль"
            app:helperText="Ребенок, Родитель или Родственник"
            app:helperTextEnabled="true"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/roleInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:focusable="false"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Icon -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/iconInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Иконка"
            app:helperText="Выберите иконку для карты"
            app:helperTextEnabled="true"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/iconInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:focusable="false"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Phone Number with contact picker -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/childPhoneInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Телефон"
            app:helperText="Опционально, из контактов или вручную"
            app:helperTextEnabled="true"
            app:endIconMode="custom"
            app:endIconDrawable="@android:drawable/ic_menu_call"
            app:endIconContentDescription="Выбрать из контактов"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/childPhoneInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="phone"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Permissions -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Разрешения"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp">

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/featureChatCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Чат" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/featureMapCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Карта" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/featureAudioCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Прослушка" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/featurePhotoCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Фото" />
        </LinearLayout>

        <!-- Info Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/colorSecondaryContainer"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💡 Как получить Device ID?"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSecondaryContainer"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. Откройте ParentWatch на устройстве ребенка\n2. Зайдите в Настройки\n3. Нажмите на Device ID для копирования\n4. Вернитесь сюда и нажмите 📋 справа"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSecondaryContainer"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
